DATABASE_URL=postgresql+psycopg://news:news@127.0.0.1:5432/news_analysis
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Провайдер по умолчанию: auto | yandex | ollama
LLM_DEFAULT_PROVIDER=auto

# Yandex Cloud → Foundation Models → YandexGPT
YANDEX_FOLDER_ID=
YANDEX_API_KEY=
# YANDEX_IAM_TOKEN=
YANDEX_MODEL=yandexgpt
YANDEX_MODEL_VERSION=latest
YANDEX_TEMPERATURE=0.2
YANDEX_MAX_TOKENS=8000
YANDEX_TIMEOUT_SEC=120

# Локальный Ollama (используется при auto, если нет ключа Yandex)
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=qwen2.5:7b
OLLAMA_TEMPERATURE=0.2
OLLAMA_MAX_TOKENS=8000
OLLAMA_TIMEOUT_SEC=300
